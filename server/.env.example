# DeepSeek Knowledge Base Configuration

# ── LLM API ──────────────────────────────────────
# Supports all OpenAI-compatible APIs (DeepSeek, OpenAI, Ollama, vLLM, etc.)
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Legacy format (still supported, LLM_* takes priority)
# DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ── Storage ──────────────────────────────────────
# Data directory (relative to server/ or absolute path)
DATA_DIR=./data

# ── Embedding ────────────────────────────────────
# Local embedding model (auto-downloaded on first use, ~500MB)
# Cached at: ~/.cache/torch/sentence_transformers/
# If unavailable, system falls back to hash-based pseudo-embedding
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ── Similarity Thresholds ────────────────────────
# Cards with similarity >= VERSION_THRESHOLD are linked as versions
VERSION_THRESHOLD=0.95
# Cards with similarity >= RELATED_THRESHOLD are marked as related
RELATED_THRESHOLD=0.88
