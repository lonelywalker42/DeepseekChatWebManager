# DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-key-here

# API base URL (DeepSeek uses OpenAI-compatible endpoint)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# LLM Model
DEEPSEEK_MODEL=deepseek-chat

# Data directory (relative to server/ or absolute)
DATA_DIR=./data

# Embedding model (local, downloaded automatically on first use)
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Similarity thresholds
VERSION_THRESHOLD=0.95
RELATED_THRESHOLD=0.88
